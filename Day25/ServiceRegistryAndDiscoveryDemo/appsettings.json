{
  "ReverseProxy": {
    "Routes": {
      "customerRoute": {
        "ClusterId": "customerCluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "customerCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5200/"
          }
        }
      }
    }
  }
}